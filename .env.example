# Google OAuth Client IDs
# Get these from Google Cloud Console after running Terraform
# See docs/setup/gcp-setup.md for setup instructions

# iOS Client ID — for react-native-app-auth (PKCE + custom URI scheme redirect)
# MUST be an iOS type client; Web clients do NOT support custom scheme redirects
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com

# Web Client ID — for @react-native-google-signin (GMS devices)
GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com

# Huawei OAuth App ID (for HMS devices)
# Get this from Huawei AppGallery Connect
HUAWEI_OAUTH_APP_ID=
